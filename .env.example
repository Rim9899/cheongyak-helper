# ── 청약홈 공공데이터포털 API 키 ──────────────────────────
# 발급: https://www.data.go.kr/data/15098547/openapi.do
# "활용신청" 후 마이페이지 > 인증키 발급 현황에서 확인
# 디코딩(일반)키를 사용하세요 (URL인코딩된 키 X)
APT_API_KEY=여기에_발급받은_일반인증키_붙여넣기

# ── 서버 포트 (기본 3000) ─────────────────────────────────
PORT=3000

# ── 캐시 TTL (초 단위, 기본 3600 = 1시간) ────────────────
CACHE_TTL_SEC=3600
